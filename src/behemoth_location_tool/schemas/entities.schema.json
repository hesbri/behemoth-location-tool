{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Behemoth Entities Manifest",
  "description": "Manifest for entity module includes.",
  "type": "object",
  "required": ["version", "includes"],
  "properties": {
    "version": { "const": 2 },
    "includes": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "description": "Relative paths to entity module files."
    }
  },
  "additionalProperties": false
}
